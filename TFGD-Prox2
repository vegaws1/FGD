def parse_args():
    parser = argparse.ArgumentParser()

    parser.add_argument('--datasets', type=str, default='pathmnist,bloodmnist,dermamnist',
                        help='Comma-separated MedMNIST subset flags.')
    parser.add_argument('--optimizers', type=str, default='sgd,adam,proxsgd,tfgd,tfgdprox',
                        help='Comma-separated optimizer names.')
    parser.add_argument('--seeds', type=str, default='42,43,44',
                        help='Comma-separated random seeds.')
    parser.add_argument('--prox_mu_values', type=str, default='1e-5,1e-4,5e-4',
                        help='Comma-separated proximal strengths for proximal optimizers.')

    parser.add_argument('--epochs', type=int, default=20)
    parser.add_argument('--batch_size', type=int, default=64)
    parser.add_argument('--size', type=int, default=28)
    parser.add_argument('--lr', type=float, default=1e-3)
    parser.add_argument('--alpha', type=float, default=0.6)
    parser.add_argument('--lam', type=float, default=0.5)
    parser.add_argument('--M', type=int, default=20)
    parser.add_argument('--M_feature', type=int, default=20)
    parser.add_argument('--M_classifier', type=int, default=20)
    parser.add_argument('--weight_decay', type=float, default=0.0)
    parser.add_argument('--momentum', type=float, default=0.9)
    parser.add_argument('--patience', type=int, default=5)
    parser.add_argument('--device', type=str, default='auto')
    parser.add_argument('--output_dir', type=str, default='outputs_v2')
    parser.add_argument('--layer_specific_prox', action='store_true', default=True)
    parser.add_argument('--prox_mu_feature_scale', type=float, default=0.1,
                        help='Feature-layer prox = prox_mu * prox_mu_feature_scale when layer_specific_prox=True.')

    parser.add_argument('--mode', type=str, default='grid', choices=['single', 'grid'])
    parser.add_argument('--data_flag', type=str, default='pathmnist')
    parser.add_argument('--optimizer', type=str, default='tfgdprox',
                        choices=['sgd', 'adam', 'proxsgd', 'tfgd', 'tfgdprox'])
    parser.add_argument('--seed', type=int, default=42)
    parser.add_argument('--prox_mu', type=float, default=1e-4)

    # Notebook-safe
    args, _ = parser.parse_known_args()
    return args


