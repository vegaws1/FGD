# ============================================================
# 6. Stage-1 robust initialization
# ============================================================

def build_arx_regressors(U, Y, na=2, nb=2):
    N, T, p = U.shape
    _, _, s = Y.shape
    maxlag = max(na, nb)

    Xreg = []
    Yreg = []

    for n in range(N):
        u = U[n]
        y = Y[n]
        for t in range(maxlag, T):
            feat = []
            for i in range(na):
                feat.extend((-y[t - i - 1]).tolist())
            for j in range(nb):
                feat.extend((u[t - j - 1]).tolist())
            Xreg.append(feat)
            Yreg.append(y[t].tolist())

    Xreg = np.asarray(Xreg, dtype=np.float64)
    Yreg = np.asarray(Yreg, dtype=np.float64)
    return Xreg, Yreg

def robust_stage1_arx_fit(U_step, Y_step, na=2, nb=2, max_iter=400, shrink=0.5):
    Xreg, Yreg = build_arx_regressors(U_step, Y_step, na=na, nb=nb)
    s = Yreg.shape[1]
    p = U_step.shape[2]

    coefs = []
    preds = np.zeros_like(Yreg)

    for k in range(s):
        model = HuberRegressor(
            epsilon=1.35,
            alpha=1e-4,
            fit_intercept=False,
            max_iter=max_iter
        )
        model.fit(Xreg, Yreg[:, k])
        ck = model.coef_.copy()
        coefs.append(ck)
        preds[:, k] = Xreg @ ck

    coefs = np.stack(coefs, axis=0)

    A_init = np.zeros((na, s, s), dtype=np.float64)
    B_init = np.zeros((nb, s, p), dtype=np.float64)

    idx = 0
    for i in range(na):
        A_init[i] = coefs[:, idx:idx + s]
        idx += s
    for j in range(nb):
        B_init[j] = coefs[:, idx:idx + p]
        idx += p

    resid = Yreg - preds
    R_prev = resid[:-1]
    R_curr = resid[1:]
    Phi_T, _, _, _ = np.linalg.lstsq(R_prev, R_curr, rcond=None)
    Phi_init = Phi_T.T[None, :, :]

    A_init *= shrink
    B_init *= shrink
    Phi_init *= shrink
    return A_init, B_init, Phi_init

