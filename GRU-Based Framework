    save_json({"best_lambda_noise": best_lambda_noise}, os.path.join(seed_dir, "best_noise_weight.json"))

    # Stage B
    final_model, history_B, best_epoch_B, best_val_B = train_model(
        final_model, train_loader, val_loader,
        epochs=80 if DEVICE == "cuda" else 60,
        lr=best_cfg["lr"] * 0.5,
