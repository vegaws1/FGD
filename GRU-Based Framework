# 7B. Baseline models and helpers
# ============================================================
class DirectGRUBaseline(nn.Module):
    """
    Direct sequence-to-sequence GRU baseline:
    U -> X directly, without explicit Hammerstein decomposition,
    without structured linear dynamic block, and without noise head.
    """
    def __init__(self, in_dim, out_dim,
                 hidden_size=64, num_layers=2,
                 dropout=0.0, channel_weights=None):
        super().__init__()
        self.out_dim = out_dim
        self.gru = nn.GRU(
            input_size=in_dim,
            hidden_size=hidden_size,
            num_layers=num_layers,
            batch_first=True,
            dropout=(dropout if num_layers > 1 else 0.0),
        )
        self.fc = nn.Sequential(
            nn.Linear(hidden_size, hidden_size),
            nn.GELU(),
            nn.Linear(hidden_size, out_dim),
        )
        self.skip = nn.Linear(in_dim, out_dim)
        if channel_weights is None:
            channel_weights = np.ones((out_dim,), dtype=np.float32)
        self.register_buffer("channel_weights", torch.tensor(channel_weights, dtype=DTYPE))

    @staticmethod
    def _peak_mask(dtrue, percentile=90):
        mag = torch.abs(dtrue)
        threshold = torch.quantile(mag.reshape(-1), percentile / 100.0)
        return (mag > threshold).float()

    def _weighted_huber_channelwise(self, pred, true):
        per_elem = F.smooth_l1_loss(pred, true, reduction="none")
        per_channel = per_elem.mean(dim=(0, 1))
        w = self.channel_weights / (self.channel_weights.sum() + 1e-8)
        return torch.sum(w * per_channel)

    def _weighted_mse_channelwise(self, pred, true):
        per_elem = (pred - true) ** 2
        per_channel = per_elem.mean(dim=(0, 1))
        w = self.channel_weights / (self.channel_weights.sum() + 1e-8)
        return torch.sum(w * per_channel)

    def _weighted_peak_loss(self, dpred, dtrue, mask):
        w = self.channel_weights.view(1, 1, -1)
        err = torch.abs(dpred - dtrue)
        weighted_mask = mask * w
        return torch.sum(weighted_mask * err) / (torch.sum(weighted_mask) + 1e-6)

    def forward(self, u):
        h_gru, _ = self.gru(u)
        x_hat = self.fc(h_gru) + self.skip(u)
        return x_hat

    def losses(self, u, x_true,
               lambda_reg=1e-4,
               lambda_diff=0.10,
               lambda_peak=0.10):
        x_hat = self.forward(u)
        pred_loss = self._weighted_huber_channelwise(x_hat, x_true)
        dx_true = x_true[:, 1:, :] - x_true[:, :-1, :]
        dx_hat = x_hat[:, 1:, :] - x_hat[:, :-1, :]
        diff_loss = self._weighted_mse_channelwise(dx_hat, dx_true)
        mask = self._peak_mask(dx_true, percentile=90)
        if mask.sum() > 0:
            peak_loss = self._weighted_peak_loss(dx_hat, dx_true, mask)
        else:
            peak_loss = torch.tensor(0.0, device=x_true.device, dtype=x_true.dtype)
        reg = sum(torch.mean(p ** 2) for p in self.parameters())
        total = pred_loss + lambda_diff * diff_loss + lambda_peak * peak_loss + lambda_reg * reg
        logs = {
            "total": float(total.item()),
            "pred_loss": float(pred_loss.item()),
            "diff_loss": float(diff_loss.item()),
            "peak_loss": float(peak_loss.item()),
            "one_step_loss": 0.0,
            "noise_loss": 0.0,
            "anchor_A": 0.0,
            "anchor_B": 0.0,
            "anchor_Phi": 0.0,
            "reg": float(reg.item()),
        }
        return total, logs, x_hat


def run_epoch_direct_gru(model, loader, optimizer=None, grad_clip=1.0,
                         lambda_reg=1e-4,
                         lambda_diff=0.10,
                         lambda_peak=0.10):
    is_train = optimizer is not None
    model.train(is_train)
    total_loss = 0.0
    pred_loss_acc = 0.0
    diff_loss_acc = 0.0
    peak_loss_acc = 0.0
    reg_acc = 0.0
    n_batches = 0
    for u, x_true, y_meas in loader:
        u = u.to(DEVICE)
        x_true = x_true.to(DEVICE)
        if is_train:
            optimizer.zero_grad()
        loss, logs, _ = model.losses(
            u, x_true,
            lambda_reg=lambda_reg,
            lambda_diff=lambda_diff,
            lambda_peak=lambda_peak,
        )
        if is_train:
            loss.backward()
            nn.utils.clip_grad_norm_(model.parameters(), grad_clip)
            optimizer.step()
        total_loss += logs["total"]
        pred_loss_acc += logs["pred_loss"]
        diff_loss_acc += logs["diff_loss"]
        peak_loss_acc += logs["peak_loss"]
        reg_acc += logs["reg"]
        n_batches += 1
    return {
        "total": total_loss / max(n_batches, 1),
        "pred_loss": pred_loss_acc / max(n_batches, 1),
        "diff_loss": diff_loss_acc / max(n_batches, 1),
        "peak_loss": peak_loss_acc / max(n_batches, 1),
        "reg": reg_acc / max(n_batches, 1),
    }


def train_direct_gru_baseline(model, train_loader, val_loader,
                              epochs=60, lr=1e-3,
                              lambda_reg=1e-4,
                              lambda_diff=0.10,
                              lambda_peak=0.10,
                              grad_clip=1.0,
                              early_stop_patience=12,
                              verbose=False):
    optimizer = torch.optim.AdamW(model.parameters(), lr=lr, weight_decay=1e-5)
    scheduler = make_cosine_scheduler(optimizer, T_max=epochs, eta_min=lr / 100)
    best_state = None
    best_val = np.inf
    best_epoch = 0
    history = []
    patience_counter = 0
    for ep in range(1, epochs + 1):
        train_logs = run_epoch_direct_gru(model, train_loader, optimizer=optimizer,
                                          grad_clip=grad_clip,
                                          lambda_reg=lambda_reg,
                                          lambda_diff=lambda_diff,
                                          lambda_peak=lambda_peak)
        with torch.no_grad():
            val_logs = run_epoch_direct_gru(model, val_loader, optimizer=None,
                                            grad_clip=grad_clip,
                                            lambda_reg=lambda_reg,
                                            lambda_diff=lambda_diff,
                                            lambda_peak=lambda_peak)
        scheduler.step()
        history.append((train_logs, val_logs))
        if val_logs["total"] < best_val:
            best_val = val_logs["total"]
            best_state = copy.deepcopy(model.state_dict())
            best_epoch = ep
            patience_counter = 0
        else:
            patience_counter += 1
        if verbose and (ep == 1 or ep % 10 == 0 or ep == epochs):
            print(f"[DirectGRU] Epoch {ep:03d} | Train={train_logs['total']:.5f} | Val={val_logs['total']:.5f}")
        if patience_counter >= early_stop_patience:
            break
    if best_state is not None:
        model.load_state_dict(best_state)
    return model, history, best_epoch, best_val


def predict_direct_gru(model, loader):
    model.eval()
    all_xtrue, all_ymeas, all_xhat = [], [], []
    with torch.no_grad():
        for u, x_true, y_meas in loader:
            u = u.to(DEVICE)
            x_hat = model(u)
            all_xtrue.append(x_true.numpy())
            all_ymeas.append(y_meas.numpy())
            all_xhat.append(x_hat.cpu().numpy())
    Xtrue = np.concatenate(all_xtrue, axis=0)
    Ymeas = np.concatenate(all_ymeas, axis=0)
    Xhat = np.concatenate(all_xhat, axis=0)
    return Xtrue, Ymeas, Xhat


def fit_random_arx_baseline(U_train, X_train, na=2, nb=2, max_iter=400):
    Xreg, Yreg = build_arx_regressors(U_train, X_train, na=na, nb=nb)
    s = Yreg.shape[1]
    p = U_train.shape[2]
    coefs = []
    for k in range(s):
        model = HuberRegressor(epsilon=1.35, alpha=1e-4, fit_intercept=False, max_iter=max_iter)
        model.fit(Xreg, Yreg[:, k])
        coefs.append(model.coef_.copy())
    coefs = np.stack(coefs, axis=0)
    A_hat = np.zeros((na, s, s), dtype=np.float64)
    B_hat = np.zeros((nb, s, p), dtype=np.float64)
    idx = 0
    for i in range(na):
        A_hat[i] = coefs[:, idx:idx + s]
        idx += s
    for j in range(nb):
        B_hat[j] = coefs[:, idx:idx + p]
        idx += p
    return A_hat, B_hat


def simulate_arx_baseline(U, A_hat, B_hat, na=2, nb=2):
    N, T, p = U.shape
    s = A_hat.shape[1]
    Xhat = np.zeros((N, T, s), dtype=np.float64)
    for n in range(N):
        for t in range(T):
            cur = np.zeros((s,), dtype=np.float64)
            for i in range(na):
                if t - i - 1 >= 0:
                    cur -= A_hat[i] @ Xhat[n, t - i - 1]
            for j in range(nb):
                if t - j - 1 >= 0:
                    cur += B_hat[j] @ U[n, t - j - 1]
            Xhat[n, t] = cur
    return Xhat

