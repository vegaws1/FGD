    )

    X_val_true_n_b1, Y_val_meas_n_b1, X_val_hat_n_b1 = predict_direct_gru(direct_gru, val_loader)
    X_test_true_n_b1, Y_test_meas_n_b1, X_test_hat_n_b1 = predict_direct_gru(direct_gru, test_loader)

    X_val_hat_b1 = x_scaler.inverse_transform(X_val_hat_n_b1)
    X_test_hat_b1 = x_scaler.inverse_transform(X_test_hat_n_b1)

    baseline_results["direct_gru"] = {
        "validation_on_X": evaluate_metrics_with_channels(X_val_true, X_val_hat_b1),
        "test_on_X": evaluate_metrics_with_channels(X_test_true, X_test_hat_b1),
        "validation_vs_Y": evaluate_metrics_with_channels(Y_val_meas, X_val_hat_b1),
        "test_vs_Y": evaluate_metrics_with_channels(Y_test_meas, X_test_hat_b1),
        "best_epoch": int(direct_best_epoch),
        "best_val": float(direct_best_val),
    }

    # ------------------------
    # Baseline 2: Linear ARX
    # ------------------------
    A_arx, B_arx = fit_random_arx_baseline(U_train_n, X_train_n, na=cfg.na, nb=cfg.nb, max_iter=400)

    X_val_hat_arx_n = simulate_arx_baseline(U_val_n, A_arx, B_arx, na=cfg.na, nb=cfg.nb)
    X_test_hat_arx_n = simulate_arx_baseline(U_test_n, A_arx, B_arx, na=cfg.na, nb=cfg.nb)

    X_val_hat_arx = x_scaler.inverse_transform(X_val_hat_arx_n)
    X_test_hat_arx = x_scaler.inverse_transform(X_test_hat_arx_n)

    baseline_results["linear_arx"] = {
        "validation_on_X": evaluate_metrics_with_channels(X_val_true, X_val_hat_arx),
        "test_on_X": evaluate_metrics_with_channels(X_test_true, X_test_hat_arx),
        "validation_vs_Y": evaluate_metrics_with_channels(Y_val_meas, X_val_hat_arx),
        "test_vs_Y": evaluate_metrics_with_channels(Y_test_meas, X_test_hat_arx),
    }

    save_json(baseline_results, os.path.join(seed_dir, "baseline_metrics.json"))

    baseline_rows = []
    for baseline_name, result_block in baseline_results.items():
        if not isinstance(result_block, dict):
            continue
        row = {"baseline": baseline_name}
        for split_name in ["validation_on_X", "test_on_X", "validation_vs_Y", "test_vs_Y"]:
            if split_name in result_block:
                row.update(flatten_metric_block(f"{baseline_name}_{split_name}", result_block[split_name]))
        baseline_rows.append(row)

    save_csv_dicts(baseline_rows, os.path.join(seed_dir, "baseline_metrics_summary.csv"))

    # Figures
    figures_dir = os.path.join(seed_dir, "figures")
    plot_training_history(history, title_prefix=f"Benchmark Seed {seed}", save_dir=figures_dir)

    plot_expected_style_figures(
        Y_true=X_test_true, Y_pred=X_test_hat, history=history,
        seq_idx=0, channel=1, zoom_start=20, zoom_end=40,
        bins=30, prefix="deterministic_X_channel2", save_dir=figures_dir
    )
    plot_expected_style_figures(
        Y_true=Y_test_meas, Y_pred=X_test_hat, history=history,
        seq_idx=0, channel=1, zoom_start=20, zoom_end=40,
        bins=30, prefix="measured_Y_channel2", save_dir=figures_dir
    )

    # Return one flat summary row for aggregation
    seed_row = {
        "seed": seed,
        "seed_dir": seed_dir,
        **flatten_metric_block("validation_on_X", metrics_val_X),
        **flatten_metric_block("test_on_X", metrics_test_X),
        **flatten_metric_block("validation_vs_Y", metrics_val_Y),
        **flatten_metric_block("test_vs_Y", metrics_test_Y),
        **param_errors
    }
    # Append flattened baseline metrics
    for baseline_name, result_block in baseline_results.items():
        if not isinstance(result_block, dict):
            continue
        for split_name in ["validation_on_X", "test_on_X", "validation_vs_Y", "test_vs_Y"]:
            if split_name in result_block:
                seed_row.update(
                    flatten_metric_block(
                        f"baseline_{baseline_name}_{split_name}",
                        result_block[split_name]
                    )
                )
    return seed_row

# ============================================================
# 16. Main multi-seed driver
# ============================================================

def main():
    warnings.filterwarnings("ignore")

    cfg = PlantConfig(
        in_dim=2,
        latent_dim=2,
        out_dim=2,
        hidden_dim=12,
        na=2,
        nb=2,
        noise_ar_order=1,
        student_df=5.0
    )
    exp = ExperimentConfig()

    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    root_dir = os.path.join(exp.output_root, f"multiseed_{DEVICE}_{timestamp}")
    ensure_dir(root_dir)

    # choose seeds
    seeds = [1234, 2025, 2026, 3030, 4040]

    save_json(
        {
            "device": DEVICE,
            "seeds": seeds,
            "plant_config": asdict(cfg),
            "experiment_config": asdict(exp)
        },
        os.path.join(root_dir, "multiseed_run_config.json")
    )

    all_seed_rows = []

    for seed in seeds:
        row = run_single_seed(seed=seed, root_dir=root_dir, cfg=cfg, exp=exp)
        all_seed_rows.append(row)

    # Save per-seed summary
    save_csv_dicts(all_seed_rows, os.path.join(root_dir, "all_seed_summaries.csv"))

    # Aggregate
    agg_rows = aggregate_seed_rows(all_seed_rows)
    save_csv_dicts(agg_rows, os.path.join(root_dir, "aggregate_mean_std.csv"))
    save_json(
        {
            "per_seed": all_seed_rows,
            "aggregate": agg_rows
        },
        os.path.join(root_dir, "aggregate_results.json")
    )
    # ========================================================
    # Compact aggregate summary for baseline comparisons
    # ========================================================
    baseline_summary_rows = []
    baseline_names = ["direct_gru", "linear_arx"]

    for bname in baseline_names:
        row = {"baseline": bname}
        for split in ["test_on_X", "test_vs_Y"]:
            for metric in ["RMSE", "R2", "FIT", "wMAPE"]:
                key = f"baseline_{bname}_{split}_{metric}"
                vals = np.array([r.get(key, np.nan) for r in all_seed_rows], dtype=float)
                if np.all(np.isnan(vals)):
                    continue
                row[f"{split}_{metric}_mean"] = float(np.nanmean(vals))
                row[f"{split}_{metric}_std"] = float(np.nanstd(vals))
        baseline_summary_rows.append(row)

    save_csv_dicts(baseline_summary_rows, os.path.join(root_dir, "baseline_aggregate_summary.csv"))

    print("\n======================================================")
    print("MULTI-SEED BENCHMARK COMPLETE")
    print(f"All outputs saved to:\n  {root_dir}")
    print("======================================================")

if __name__ == "__main__":
    main()
