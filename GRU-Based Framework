def automatic_hyperparameter_search(
    in_dim, latent_dim, out_dim,
    na, nb, noise_ar_order,
    A_init, B_init, Phi_init,
    train_loader, val_loader,
    channel_weights,
    max_trials=None,
    search_epochs=20,
    rng_seed=2026
):
    rng = random.Random(rng_seed)

    hidden_candidates = [32, 48, 64]
    layer_candidates = [1, 2]
    dropout_candidates = [0.0, 0.1]
    lr_candidates = [5e-4, 7e-4, 1e-3]
    lambda_diff_candidates = [0.10, 0.20]
    lambda_peak_candidates = [0.10, 0.20]
    lambda_one_step_candidates = [0.05, 0.10, 0.20]

    all_configs = list(product(
        hidden_candidates,
        layer_candidates,
        dropout_candidates,
        lr_candidates,
        lambda_diff_candidates,
        lambda_peak_candidates,
        lambda_one_step_candidates
    ))
    rng.shuffle(all_configs)

    if max_trials is None:
        max_trials = 24 if DEVICE == "cuda" else 12

    trial_configs = all_configs[:max_trials]

    best_cfg = None
    best_score = np.inf
    all_results = []

    print("\n[Automatic Hyperparameter Search - Final Benchmark]")
    print(f"Search budget: {max_trials} trials on device={DEVICE}")

    for trial_id, cfg_trial in enumerate(trial_configs, start=1):
        hidden_size, num_layers, dropout, lr, lambda_diff, lambda_peak, lambda_one_step = cfg_trial

        print(
            f"  Trial {trial_id:02d}/{max_trials} -> "
            f"hidden={hidden_size}, layers={num_layers}, dropout={dropout}, lr={lr}, "
            f"lambda_diff={lambda_diff}, lambda_peak={lambda_peak}, lambda_one_step={lambda_one_step}"
        )

        model = StrongHammersteinModel(
            in_dim=in_dim,
            latent_dim=latent_dim,
            out_dim=out_dim,
            hidden_size=hidden_size,
            num_layers=num_layers,
            dropout=dropout,
            na=na,
            nb=nb,
            noise_ar_order=noise_ar_order,
            A_init=A_init,
            B_init=B_init,
            Phi_init=Phi_init,
            channel_weights=channel_weights
        ).to(DEVICE)

        model, _, _, _ = train_model(
            model, train_loader, val_loader,
            epochs=search_epochs,
            lr=lr,
            lambda_noise=0.0,
            lambda_reg=1e-4,
            lambda_diff=lambda_diff,
            lambda_peak=lambda_peak,
            lambda_one_step=lambda_one_step,
            lambda_anchor_A=0.01,
            lambda_anchor_B=0.01,
            lambda_anchor_Phi=0.002,
            grad_clip=1.0,
            verbose=False,
            early_stop_patience=6,
            use_cosine=False,
            train_nonlinear=True,
            train_linear=True,
            train_noise=False
        )

        with torch.no_grad():
            val_logs = run_epoch(
                model, val_loader, optimizer=None,
                lambda_noise=0.0,
                lambda_reg=1e-4,
                lambda_diff=lambda_diff,
                lambda_peak=lambda_peak,
                lambda_one_step=lambda_one_step,
                lambda_anchor_A=0.01,
                lambda_anchor_B=0.01,
                lambda_anchor_Phi=0.002,
                train_nonlinear=True,
                train_linear=True,
                train_noise=False
            )

        score = (
            val_logs["pred_loss"]
            + 0.15 * val_logs["diff_loss"]
            + 0.10 * val_logs["peak_loss"]
            + 0.20 * val_logs["one_step_loss"]
        )

        result = {
            "hidden_size": hidden_size,
            "num_layers": num_layers,
            "dropout": dropout,
            "lr": lr,
            "lambda_diff": lambda_diff,
            "lambda_peak": lambda_peak,
            "lambda_one_step": lambda_one_step,
            "val_total_loss": val_logs["total"],
            "val_pred_loss": val_logs["pred_loss"],
            "val_diff_loss": val_logs["diff_loss"],
            "val_peak_loss": val_logs["peak_loss"],
            "val_one_step_loss": val_logs["one_step_loss"],
            "score": score,
        }
        all_results.append(result)

        print(
            f"     val_total={val_logs['total']:.6f}, "
            f"pred={val_logs['pred_loss']:.6f}, "
            f"diff={val_logs['diff_loss']:.6f}, "
            f"peak={val_logs['peak_loss']:.6f}, "
            f"one_step={val_logs['one_step_loss']:.6f}, "
            f"score={score:.6f}"
        )

        if score < best_score:
            best_score = score
            best_cfg = result

    print("\n[Best Hyperparameter Configuration - Final Benchmark]")
    for k, v in best_cfg.items():
        print(f"  {k}: {v}")

    return best_cfg, all_results

