    else:
        n_step_train = exp.n_step_train_cpu
        n_step_val = exp.n_step_val_cpu
        n_train = exp.n_train_cpu
        n_val = exp.n_val_cpu
        n_test = exp.n_test_cpu
        search_trials = exp.search_trials_cpu
        search_epochs = exp.search_epochs_cpu
        batch_size = exp.batch_size_cpu

    save_json(
        {
            "seed": seed,
            "device": DEVICE,
            "plant_config": asdict(cfg),
            "experiment_config": asdict(exp)
        },
        os.path.join(seed_dir, "run_config.json")
    )

    print(f"\n==================== SEED {seed} ====================")
    print(f"Using device: {DEVICE}")

    # Stage-1
    print("[Data] Generating step-signal dataset for Stage-1 initialization...")
    U_step_train, Y_step_train, X_step_train, _, _ = make_dataset(
        plant, n_sequences=n_step_train, T=exp.T_step, mode="step"
    )
    U_step_val, Y_step_val, X_step_val, _, _ = make_dataset(
        plant, n_sequences=n_step_val, T=exp.T_step, mode="step"
    )

    print("[Stage-1] Robust ARX initialization from step-signal data...")
    A_init, B_init, Phi_init = robust_stage1_arx_fit(
        U_step_train, Y_step_train,
        na=cfg.na, nb=cfg.nb,
        max_iter=400,
        shrink=0.5
    )

    np.savez(
        os.path.join(seed_dir, "arrays", "initial_params.npz"),
        A_init=A_init, B_init=B_init, Phi_init=Phi_init
    )

    # Stage-2
    print("[Data] Generating random-signal datasets for Stage-2 training...")
    U_train, Y_train, X_train, _, _ = make_dataset(plant, n_sequences=n_train, T=exp.T_main, mode="random")
    U_val, Y_val, X_val, _, _ = make_dataset(plant, n_sequences=n_val, T=exp.T_main, mode="random")
    U_test, Y_test, X_test, _, _ = make_dataset(plant, n_sequences=n_test, T=exp.T_main, mode="random")

    # Normalize
    u_scaler = StandardScalerSeq().fit(U_train)
    x_scaler = StandardScalerSeq().fit(X_train)

    U_train_n = u_scaler.transform(U_train)
    U_val_n = u_scaler.transform(U_val)
    U_test_n = u_scaler.transform(U_test)

    X_train_n = x_scaler.transform(X_train)
    X_val_n = x_scaler.transform(X_val)
    X_test_n = x_scaler.transform(X_test)

    Y_train_n = x_scaler.transform(Y_train)
    Y_val_n = x_scaler.transform(Y_val)
    Y_test_n = x_scaler.transform(Y_test)

    train_ds = StrongOutcomesDataset(U_train_n, X_train_n, Y_train_n)
    val_ds = StrongOutcomesDataset(U_val_n, X_val_n, Y_val_n)
    test_ds = StrongOutcomesDataset(U_test_n, X_test_n, Y_test_n)

    train_loader = DataLoader(train_ds, batch_size=batch_size, shuffle=True, drop_last=False)
    val_loader = DataLoader(val_ds, batch_size=batch_size, shuffle=False, drop_last=False)
    test_loader = DataLoader(test_ds, batch_size=batch_size, shuffle=False, drop_last=False)

    channel_weights = np.array([1.35, 1.00], dtype=np.float32)

    # Search
    best_cfg, all_search_results = automatic_hyperparameter_search(
        in_dim=cfg.in_dim,
        latent_dim=cfg.latent_dim,
        out_dim=cfg.out_dim,
        na=cfg.na,
        nb=cfg.nb,
        noise_ar_order=cfg.noise_ar_order,
        A_init=A_init,
        B_init=B_init,
        Phi_init=Phi_init,
        train_loader=train_loader,
        val_loader=val_loader,
        channel_weights=channel_weights,
        max_trials=search_trials,
        search_epochs=search_epochs,
        rng_seed=seed + 100
    )
    save_csv_dicts(all_search_results, os.path.join(seed_dir, "search_results.csv"))
    save_json(best_cfg, os.path.join(seed_dir, "best_hyperparams.json"))

    # Final model
    final_model = StrongHammersteinModel(
        in_dim=cfg.in_dim,
        latent_dim=cfg.latent_dim,
        out_dim=cfg.out_dim,
        hidden_size=best_cfg["hidden_size"],
