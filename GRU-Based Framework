def run_single_seed(seed, root_dir, cfg=None, exp=None):
    if cfg is None:
        cfg = PlantConfig(
            in_dim=2,
            latent_dim=2,
            out_dim=2,
            hidden_dim=12,
            na=2,
            nb=2,
            noise_ar_order=1,
            student_df=5.0
        )
    if exp is None:
        exp = ExperimentConfig()

    set_seed(seed)

    seed_dir = os.path.join(root_dir, f"seed_{seed}")
    ensure_dir(seed_dir)
    ensure_dir(os.path.join(seed_dir, "figures"))
    ensure_dir(os.path.join(seed_dir, "arrays"))

    plant = TrueMIMOHammersteinPlant(cfg)

    use_gpu_mode = (DEVICE == "cuda")
    if use_gpu_mode:
        n_step_train = exp.n_step_train_gpu
        n_step_val = exp.n_step_val_gpu
