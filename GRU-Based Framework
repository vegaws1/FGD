@dataclass
class PlantConfig:
    in_dim: int = 2
    latent_dim: int = 2
    out_dim: int = 2
    hidden_dim: int = 12
    na: int = 2
    nb: int = 2
    noise_ar_order: int = 1
    student_df: float = 5.0

class TrueMIMOHammersteinPlant:
    def __init__(self, cfg: PlantConfig):
        self.cfg = cfg
        p = cfg.in_dim
        m = cfg.latent_dim
        h = cfg.hidden_dim
        rng = np.random.default_rng(2026)

        self.Wu = rng.normal(0.0, 0.6, size=(h, p))
        self.Wh = rng.normal(0.0, 0.35, size=(h, h))
        self.bh = rng.normal(0.0, 0.15, size=(h,))
        self.Wn1 = rng.normal(0.0, 0.5, size=(h, h))
        self.bn1 = rng.normal(0.0, 0.1, size=(h,))
        self.Wn2 = rng.normal(0.0, 0.5, size=(m, h))
        self.bn2 = rng.normal(0.0, 0.1, size=(m,))

        self.A = [
            np.array([[0.34, -0.08],
                      [0.05,  0.28]], dtype=np.float64),
            np.array([[-0.10, 0.03],
                      [ 0.02, -0.07]], dtype=np.float64),
        ]
        self.B = [
            np.array([[ 0.80, 0.12],
                      [-0.05, 0.55]], dtype=np.float64),
            np.array([[ 0.20,-0.10],
                      [ 0.08, 0.15]], dtype=np.float64),
        ]

        self.Phi = np.array([[0.65, 0.12],
                             [0.08, 0.55]], dtype=np.float64)
        self.chol = np.array([[0.12, 0.00],
                              [0.04, 0.10]], dtype=np.float64)

    def nonlinear_block(self, u_seq):
        T, p = u_seq.shape
        h = self.cfg.hidden_dim
        m = self.cfg.latent_dim

        h_t = np.zeros(h, dtype=np.float64)
        n_seq = np.zeros((T, m), dtype=np.float64)

        for t in range(T):
            u_t = u_seq[t]
            z = np.tanh(self.Wu @ u_t + self.Wh @ h_t + self.bh)
            h_t = 0.70 * h_t + 0.30 * z
            z2 = np.tanh(self.Wn1 @ h_t + self.bn1)

            coupled = np.zeros(m, dtype=np.float64)
            if m >= 2 and p >= 2:
                coupled[0] = 0.18 * np.sin(u_t[0]) * u_t[1]
                coupled[1] = 0.16 * np.cos(u_t[1]) * u_t[0]

            n_t = self.Wn2 @ z2 + self.bn2 + coupled
            n_seq[t] = n_t

        return n_seq

    def linear_dynamic_block(self, n_seq):
        T, m = n_seq.shape
        s = self.cfg.out_dim
        x_hist = [np.zeros(s, dtype=np.float64) for _ in range(T)]

        for t in range(T):
            cur = np.zeros(s, dtype=np.float64)
            for i in range(self.cfg.na):
                if t - i - 1 >= 0:
                    cur -= self.A[i] @ x_hist[t - i - 1]
            for j in range(self.cfg.nb):
                if t - j - 1 >= 0:
                    cur += self.B[j] @ n_seq[t - j - 1]
            x_hist[t] = cur

        return np.stack(x_hist, axis=0)

    def correlated_measurement_noise(self, T):
        s = self.cfg.out_dim
        df = self.cfg.student_df
        eps = np.random.standard_t(df=df, size=(T, s)) @ self.chol.T
        eta = np.zeros((T, s), dtype=np.float64)

        for t in range(T):
            cur = eps[t].copy()
            if t - 1 >= 0:
                cur += self.Phi @ eta[t - 1]
            eta[t] = cur

        return eta

    def simulate(self, u_seq):
        n_seq = self.nonlinear_block(u_seq)
        x_seq = self.linear_dynamic_block(n_seq)
        eta = self.correlated_measurement_noise(len(u_seq))
        y_seq = x_seq + eta
        return n_seq, x_seq, eta, y_seq

# ============================================================
# 3. Input generation
# ============================================================

def generate_step_sequence(T, in_dim=2, amp_low=-1.5, amp_high=1.5,
                           min_hold=8, max_hold=20):
    u = np.zeros((T, in_dim), dtype=np.float64)
    t = 0
    while t < T:
        hold = np.random.randint(min_hold, max_hold + 1)
        level = np.random.uniform(amp_low, amp_high, size=(in_dim,))
        u[t:min(T, t + hold)] = level
        t += hold
    return u

def generate_random_sequence(T, in_dim=2, smooth=True):
    u = np.random.uniform(-1.6, 1.6, size=(T, in_dim)).astype(np.float64)
    if smooth:
        for k in range(in_dim):
            for t in range(1, T):
                u[t, k] = 0.82 * u[t - 1, k] + 0.18 * u[t, k]
    return u

def make_dataset(plant, n_sequences, T, mode="random"):
    U, Y, X, N, E = [], [], [], [], []

    for _ in range(n_sequences):
        if mode == "step":
            u = generate_step_sequence(T, in_dim=plant.cfg.in_dim)
        else:
            u = generate_random_sequence(T, in_dim=plant.cfg.in_dim, smooth=True)

        n_seq, x_seq, eta, y_seq = plant.simulate(u)

        U.append(u)
        Y.append(y_seq)
        X.append(x_seq)
        N.append(n_seq)
        E.append(eta)

    U = np.stack(U, axis=0)
    Y = np.stack(Y, axis=0)
    X = np.stack(X, axis=0)
    N = np.stack(N, axis=0)
    E = np.stack(E, axis=0)

    return U, Y, X, N, E

