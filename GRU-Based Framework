def set_requires_grad(module, flag=True):
    for p in module.parameters():
        p.requires_grad = flag

def run_epoch(model, loader, optimizer=None, grad_clip=1.0,
              lambda_noise=0.005, lambda_reg=1e-4,
              lambda_diff=0.10, lambda_peak=0.10,
              lambda_one_step=0.10,
              lambda_anchor_A=0.005, lambda_anchor_B=0.005, lambda_anchor_Phi=0.002,
              train_nonlinear=True, train_linear=True, train_noise=True):
    is_train = optimizer is not None
    model.train(is_train)

    set_requires_grad(model.nonlinear, train_nonlinear)
    set_requires_grad(model.linear, train_linear)
    set_requires_grad(model.noise, train_noise)

    total_loss = 0.0
    pred_loss_acc = 0.0
    diff_loss_acc = 0.0
    peak_loss_acc = 0.0
    one_step_acc = 0.0
    noise_loss_acc = 0.0
    anchor_A_acc = 0.0
    anchor_B_acc = 0.0
    anchor_Phi_acc = 0.0
    reg_acc = 0.0
    n_batches = 0

    for u, x_true, y_meas in loader:
        u = u.to(DEVICE)
        x_true = x_true.to(DEVICE)
        y_meas = y_meas.to(DEVICE)

        if is_train:
            optimizer.zero_grad()

        loss, logs, _ = model.losses(
            u, x_true, y_meas,
            lambda_noise=lambda_noise,
            lambda_reg=lambda_reg,
            lambda_diff=lambda_diff,
            lambda_peak=lambda_peak,
            lambda_one_step=lambda_one_step,
            lambda_anchor_A=lambda_anchor_A,
            lambda_anchor_B=lambda_anchor_B,
            lambda_anchor_Phi=lambda_anchor_Phi
        )

        if is_train:
            loss.backward()
            nn.utils.clip_grad_norm_(model.parameters(), grad_clip)
            optimizer.step()

        total_loss += logs["total"]
        pred_loss_acc += logs["pred_loss"]
        diff_loss_acc += logs["diff_loss"]
        peak_loss_acc += logs["peak_loss"]
        one_step_acc += logs["one_step_loss"]
        noise_loss_acc += logs["noise_loss"]
        anchor_A_acc += logs["anchor_A"]
        anchor_B_acc += logs["anchor_B"]
        anchor_Phi_acc += logs["anchor_Phi"]
        reg_acc += logs["reg"]
        n_batches += 1

    return {
        "total": total_loss / max(n_batches, 1),
        "pred_loss": pred_loss_acc / max(n_batches, 1),
        "diff_loss": diff_loss_acc / max(n_batches, 1),
        "peak_loss": peak_loss_acc / max(n_batches, 1),
        "one_step_loss": one_step_acc / max(n_batches, 1),
        "noise_loss": noise_loss_acc / max(n_batches, 1),
        "anchor_A": anchor_A_acc / max(n_batches, 1),
        "anchor_B": anchor_B_acc / max(n_batches, 1),
        "anchor_Phi": anchor_Phi_acc / max(n_batches, 1),
        "reg": reg_acc / max(n_batches, 1),
    }

def train_model(model, train_loader, val_loader,
                epochs=100, lr=1e-3,
                lambda_noise=0.005, lambda_reg=1e-4,
                lambda_diff=0.10, lambda_peak=0.10,
                lambda_one_step=0.10,
                lambda_anchor_A=0.005, lambda_anchor_B=0.005, lambda_anchor_Phi=0.002,
                grad_clip=1.0, verbose=True,
                early_stop_patience=20, use_cosine=True,
                train_nonlinear=True, train_linear=True, train_noise=True):
    optimizer = torch.optim.AdamW(model.parameters(), lr=lr, weight_decay=1e-5)
    scheduler = make_cosine_scheduler(optimizer, T_max=epochs, eta_min=lr / 100) if use_cosine else None

    best_state = None
    best_val = np.inf
    best_epoch = 0
    history = []
    patience_counter = 0

    for ep in range(1, epochs + 1):
        train_logs = run_epoch(
            model, train_loader, optimizer=optimizer,
            grad_clip=grad_clip,
            lambda_noise=lambda_noise,
            lambda_reg=lambda_reg,
            lambda_diff=lambda_diff,
            lambda_peak=lambda_peak,
            lambda_one_step=lambda_one_step,
            lambda_anchor_A=lambda_anchor_A,
            lambda_anchor_B=lambda_anchor_B,
            lambda_anchor_Phi=lambda_anchor_Phi,
            train_nonlinear=train_nonlinear,
            train_linear=train_linear,
            train_noise=train_noise
        )

        with torch.no_grad():
            val_logs = run_epoch(
                model, val_loader, optimizer=None,
                grad_clip=grad_clip,
                lambda_noise=lambda_noise,
                lambda_reg=lambda_reg,
                lambda_diff=lambda_diff,
                lambda_peak=lambda_peak,
                lambda_one_step=lambda_one_step,
                lambda_anchor_A=lambda_anchor_A,
                lambda_anchor_B=lambda_anchor_B,
                lambda_anchor_Phi=lambda_anchor_Phi,
                train_nonlinear=True,
                train_linear=True,
                train_noise=True
            )

        if scheduler is not None:
            scheduler.step()

        history.append((train_logs, val_logs))

        if val_logs["total"] < best_val:
            best_val = val_logs["total"]
            best_state = copy.deepcopy(model.state_dict())
            best_epoch = ep
            patience_counter = 0
        else:
            patience_counter += 1

        if verbose and (ep == 1 or ep % 10 == 0 or ep == epochs):
            lr_now = optimizer.param_groups[0]["lr"]
            print(
                f"Epoch {ep:03d} | LR={lr_now:.2e} | "
                f"Train total={train_logs['total']:.5f}, pred={train_logs['pred_loss']:.5f}, "
                f"diff={train_logs['diff_loss']:.5f}, peak={train_logs['peak_loss']:.5f}, "
                f"one_step={train_logs['one_step_loss']:.5f}, noise={train_logs['noise_loss']:.5f} | "
                f"Val total={val_logs['total']:.5f}, pred={val_logs['pred_loss']:.5f}, "
                f"diff={val_logs['diff_loss']:.5f}, peak={val_logs['peak_loss']:.5f}, "
                f"one_step={val_logs['one_step_loss']:.5f}, noise={val_logs['noise_loss']:.5f}"
            )

        if patience_counter >= early_stop_patience:
            if verbose:
                print(f"Early stopping at epoch {ep}, best epoch was {best_epoch} with val total={best_val:.5f}")
            break

    if best_state is not None:
        model.load_state_dict(best_state)

    return model, history, best_epoch, best_val

