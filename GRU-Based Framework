class GRUNonlinearBlock(nn.Module):
    def __init__(self, in_dim, latent_dim,
                 hidden_size=64, num_layers=2,
                 dropout=0.1):
        super().__init__()
        self.gru = nn.GRU(
            input_size=in_dim,
            hidden_size=hidden_size,
            num_layers=num_layers,
            batch_first=True,
            dropout=(dropout if num_layers > 1 else 0.0),
        )
        self.fc = nn.Sequential(
            nn.Linear(hidden_size, hidden_size),
            nn.GELU(),
            nn.Linear(hidden_size, latent_dim),
        )
        self.skip = nn.Linear(in_dim, latent_dim)

    def forward(self, u):
        h_gru, _ = self.gru(u)
        n = self.fc(h_gru) + self.skip(u)
        return n

class LinearDynamicBlock(nn.Module):
    def __init__(self, out_dim, latent_dim, na=2, nb=2, A_init=None, B_init=None):
        super().__init__()
        self.out_dim = out_dim
        self.latent_dim = latent_dim
        self.na = na
        self.nb = nb

        if A_init is None:
            A_init = np.zeros((na, out_dim, out_dim), dtype=np.float32)
        if B_init is None:
            B_init = np.zeros((nb, out_dim, latent_dim), dtype=np.float32)

        self.A = nn.Parameter(torch.tensor(A_init, dtype=DTYPE))
        self.B = nn.Parameter(torch.tensor(B_init, dtype=DTYPE))

    def forward(self, n):
        Bsz, T, _ = n.shape
        s = self.out_dim
        x_hist = []

        for t in range(T):
            cur = torch.zeros(Bsz, s, device=n.device, dtype=n.dtype)
            for i in range(self.na):
                if t - i - 1 >= 0:
                    cur = cur - x_hist[t - i - 1] @ self.A[i].T
            for j in range(self.nb):
                if t - j - 1 >= 0:
                    cur = cur + n[:, t - j - 1, :] @ self.B[j].T
            x_hist.append(cur)

        x = torch.stack(x_hist, dim=1)
        return x

    def one_step_teacher_forced(self, n, x_teacher):
        Bsz, T, _ = n.shape
        s = self.out_dim
        x_tf = []

        for t in range(T):
            cur = torch.zeros(Bsz, s, device=n.device, dtype=n.dtype)
            for i in range(self.na):
                if t - i - 1 >= 0:
                    cur = cur - x_teacher[:, t - i - 1, :] @ self.A[i].T
            for j in range(self.nb):
                if t - j - 1 >= 0:
                    cur = cur + n[:, t - j - 1, :] @ self.B[j].T
            x_tf.append(cur)

        x_tf = torch.stack(x_tf, dim=1)
        return x_tf

class CorrelatedNoiseHead(nn.Module):
    def __init__(self, out_dim, ar_order=1, Phi_init=None, nu=5.0):
        super().__init__()
        self.out_dim = out_dim
        self.ar_order = ar_order
        self.nu = nu

        if Phi_init is None:
            Phi_init = np.zeros((ar_order, out_dim, out_dim), dtype=np.float32)

        self.Phi = nn.Parameter(torch.tensor(Phi_init, dtype=DTYPE))
        self.log_scale = nn.Parameter(torch.zeros(out_dim, dtype=DTYPE))

    def innovations(self, residual):
        Bsz, T, s = residual.shape
        innov = []

        for t in range(T):
            cur = residual[:, t, :]
            for l in range(self.ar_order):
                if t - l - 1 >= 0:
                    cur = cur - residual[:, t - l - 1, :] @ self.Phi[l].T
            innov.append(cur)

        innov = torch.stack(innov, dim=1)
        return innov

    def robust_nll(self, innovation):
        log_scale = torch.clamp(self.log_scale, min=-3.0, max=1.5)
        scale = F.softplus(log_scale) + 1e-4
        z = innovation / scale.view(1, 1, -1)
        loss = 0.5 * (self.nu + 1.0) * torch.log1p((z ** 2) / self.nu) \
               + torch.log(scale.view(1, 1, -1))
        return loss.mean()

class StrongHammersteinModel(nn.Module):
    def __init__(self, in_dim, latent_dim, out_dim,
                 hidden_size=64, num_layers=2, dropout=0.0,
                 na=2, nb=2, noise_ar_order=1,
                 A_init=None, B_init=None, Phi_init=None,
                 channel_weights=None):
        super().__init__()

        self.out_dim = out_dim
        self.na = na
        self.nb = nb

        self.nonlinear = GRUNonlinearBlock(
            in_dim=in_dim,
            latent_dim=latent_dim,
            hidden_size=hidden_size,
            num_layers=num_layers,
            dropout=dropout
        )
        self.linear = LinearDynamicBlock(
            out_dim=out_dim,
            latent_dim=latent_dim,
            na=na,
            nb=nb,
            A_init=A_init,
            B_init=B_init
        )
        self.noise = CorrelatedNoiseHead(
            out_dim=out_dim,
            ar_order=noise_ar_order,
            Phi_init=Phi_init,
            nu=5.0
        )

        if A_init is None:
            A_init = np.zeros((na, out_dim, out_dim), dtype=np.float32)
        if B_init is None:
            B_init = np.zeros((nb, out_dim, latent_dim), dtype=np.float32)
        if Phi_init is None:
            Phi_init = np.zeros((noise_ar_order, out_dim, out_dim), dtype=np.float32)

        self.register_buffer("A_anchor", torch.tensor(A_init, dtype=DTYPE))
        self.register_buffer("B_anchor", torch.tensor(B_init, dtype=DTYPE))
        self.register_buffer("Phi_anchor", torch.tensor(Phi_init, dtype=DTYPE))

        if channel_weights is None:
            channel_weights = np.ones((out_dim,), dtype=np.float32)
        self.register_buffer("channel_weights", torch.tensor(channel_weights, dtype=DTYPE))

    def forward(self, u):
        n = self.nonlinear(u)
        x = self.linear(n)
        return x, n

    @staticmethod
    def _peak_mask(dtrue, percentile=90):
        mag = torch.abs(dtrue)
        threshold = torch.quantile(mag.reshape(-1), percentile / 100.0)
        mask = (mag > threshold).float()
        return mask

    def _weighted_huber_channelwise(self, pred, true):
        per_elem = F.smooth_l1_loss(pred, true, reduction="none")
        per_channel = per_elem.mean(dim=(0, 1))
        w = self.channel_weights / (self.channel_weights.sum() + 1e-8)
        return torch.sum(w * per_channel)

    def _weighted_mse_channelwise(self, pred, true):
        per_elem = (pred - true) ** 2
        per_channel = per_elem.mean(dim=(0, 1))
        w = self.channel_weights / (self.channel_weights.sum() + 1e-8)
        return torch.sum(w * per_channel)

    def _weighted_peak_loss(self, dpred, dtrue, mask):
        w = self.channel_weights.view(1, 1, -1)
        err = torch.abs(dpred - dtrue)
        weighted_mask = mask * w
        return torch.sum(weighted_mask * err) / (torch.sum(weighted_mask) + 1e-6)

    def losses(self, u, x_true, y_meas,
               lambda_noise=0.005,
               lambda_reg=1e-4,
               lambda_diff=0.10,
               lambda_peak=0.10,
               lambda_one_step=0.10,
               lambda_anchor_A=0.005,
               lambda_anchor_B=0.005,
               lambda_anchor_Phi=0.002):
        x_hat, n = self.forward(u)

        pred_loss = self._weighted_huber_channelwise(x_hat, x_true)

        dx_true = x_true[:, 1:, :] - x_true[:, :-1, :]
        dx_hat = x_hat[:, 1:, :] - x_hat[:, :-1, :]
        diff_loss = self._weighted_mse_channelwise(dx_hat, dx_true)

        mask = self._peak_mask(dx_true, percentile=90)
        if mask.sum() > 0:
            peak_loss = self._weighted_peak_loss(dx_hat, dx_true, mask)
        else:
            peak_loss = torch.tensor(0.0, device=x_true.device, dtype=x_true.dtype)

        x_1step = self.linear.one_step_teacher_forced(n, x_true.detach())
        maxlag = max(self.na, self.nb)
        if x_true.size(1) > maxlag:
            one_step_loss = self._weighted_huber_channelwise(
                x_1step[:, maxlag:, :],
                x_true[:, maxlag:, :]
            )
        else:
            one_step_loss = torch.tensor(0.0, device=x_true.device, dtype=x_true.dtype)

        residual_meas = y_meas - x_hat
        innovation = self.noise.innovations(residual_meas)
        noise_loss = self.noise.robust_nll(innovation)

        reg = (
            torch.mean(self.linear.A ** 2) +
            torch.mean(self.linear.B ** 2) +
            torch.mean(self.noise.Phi ** 2)
        )

        anchor_A = torch.mean((self.linear.A - self.A_anchor) ** 2)
        anchor_B = torch.mean((self.linear.B - self.B_anchor) ** 2)
        anchor_Phi = torch.mean((self.noise.Phi - self.Phi_anchor) ** 2)

        total = (
            pred_loss
            + lambda_diff * diff_loss
            + lambda_peak * peak_loss
            + lambda_one_step * one_step_loss
            + lambda_noise * noise_loss
            + lambda_anchor_A * anchor_A
            + lambda_anchor_B * anchor_B
            + lambda_anchor_Phi * anchor_Phi
            + lambda_reg * reg
        )

        logs = {
            "total": float(total.item()),
            "pred_loss": float(pred_loss.item()),
            "diff_loss": float(diff_loss.item()),
            "peak_loss": float(peak_loss.item()),
            "one_step_loss": float(one_step_loss.item()),
            "noise_loss": float(noise_loss.item()),
            "anchor_A": float(anchor_A.item()),
            "anchor_B": float(anchor_B.item()),
            "anchor_Phi": float(anchor_Phi.item()),
            "reg": float(reg.item()),
        }
        return total, logs, x_hat

