def predict_model(model, loader):
    model.eval()
    all_xtrue = []
    all_ymeas = []
    all_xhat = []

    with torch.no_grad():
        for u, x_true, y_meas in loader:
            u = u.to(DEVICE)
            x_true = x_true.to(DEVICE)
            y_meas = y_meas.to(DEVICE)
            x_hat, _ = model(u)

            all_xtrue.append(x_true.cpu().numpy())
            all_ymeas.append(y_meas.cpu().numpy())
            all_xhat.append(x_hat.cpu().numpy())

    Xtrue = np.concatenate(all_xtrue, axis=0)
    Ymeas = np.concatenate(all_ymeas, axis=0)
    Xhat = np.concatenate(all_xhat, axis=0)
    return Xtrue, Ymeas, Xhat

def evaluate_metrics(Y_true, Y_pred):
    mse = mse_np(Y_true, Y_pred)
    mae = mae_np(Y_true, Y_pred)
    rmse = rmse_np(Y_true, Y_pred)
    r2 = r2_np(Y_true, Y_pred)
    nrmse = nrmse_np(Y_true, Y_pred)
    fitp = fit_percent_np(Y_true, Y_pred)
    mape = mape_np(Y_true, Y_pred)
    smape = smape_np(Y_true, Y_pred)
    wmape = wmape_np(Y_true, Y_pred)

    return {
        "MSE": float(mse),
        "MAE": float(mae),
        "RMSE": float(rmse),
        "NRMSE": float(nrmse),
        "R2": float(r2),
        "FIT": float(fitp),
        "MAPE": float(mape),
        "sMAPE": float(smape),
        "wMAPE": float(wmape),
    }

def evaluate_metrics_with_channels(Y_true, Y_pred):
    overall = evaluate_metrics(Y_true, Y_pred)
    per_channel = {}
    for k in range(Y_true.shape[-1]):
        per_channel[f"channel_{k+1}"] = evaluate_metrics(Y_true[..., k], Y_pred[..., k])
    return {"overall": overall, "per_channel": per_channel}

def print_metrics_block(name, block):
    overall = block["overall"]
    print(f"\n[{name}]")
    for k, v in overall.items():
        suffix = "%" if k in ["FIT", "MAPE", "sMAPE", "wMAPE"] else ""
        print(f"  {k:<6}= {v:.6f}{suffix}")
    for ch_name, ch_metrics in block["per_channel"].items():
        print(f"  {ch_name}:")
        for k, v in ch_metrics.items():
            suffix = "%" if k in ["FIT", "MAPE", "sMAPE", "wMAPE"] else ""
            print(f"    {k:<6}= {v:.6f}{suffix}")

