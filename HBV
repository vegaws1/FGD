def run_all_experiments(output_dir="outputs", quick=False):
    os.makedirs(output_dir, exist_ok=True)
    os.makedirs("figures", exist_ok=True)

    # ---- A. Numerical validation ----
    val_results = validation_study(
        T=30.0 if quick else 40.0,
        p=0.85,
        kernel_name="shifted_power",
    )

    # ---- B. Kernel comparison ----
    p_values = (0.70, 0.85, 0.95) if quick else (0.65, 0.80, 0.95)
    kernel_summary, trajectories = simulate_kernel_grid(
        T=40.0 if quick else 60.0,
        N=600 if quick else 1200,
        p_values=p_values,
    )
    plot_kernel_dynamics(trajectories)

    # ---- C. Surrogate dataset ----
    X, Y, meta = generate_surrogate_dataset(
        num_trajectories=18 if quick else 60,
        T=25.0 if quick else 40.0,
        N=120 if quick else 250,
        p_choices=(0.65, 0.75, 0.85, 0.95),
    )

    # ---- D. Optimizer benchmark ----
    benchmark = optimizer_benchmark(
        X, Y,
        epochs=8 if quick else 25,
        batch_size=256 if quick else 512,
        lr=1e-3,
    )
    plot_training_histories(benchmark)

    benchmark_table = []
    for opt, bundle in benchmark.items():
        row = {"optimizer": opt}
        row.update(bundle["metrics"])
        benchmark_table.append(row)

    benchmark_table = sorted(benchmark_table, key=lambda d: d["RMSE"])
    best_opt = benchmark_table[0]["optimizer"]
    best_bundle = benchmark[best_opt]

    # ---- E. Rollout on unseen scenarios across kernels ----
    rollout_summary = []
    test_kernels = list(KERNELS.keys())

    for kernel_name in test_kernels:
        p = 0.85
        pars = sample_random_params(BASE_PARAMS, scale=0.10)
        x0 = sample_random_x0(BASE_X0, scale=0.15)

        T_roll = 25.0 if quick else 40.0
        N_roll = 120 if quick else 220

        t_true, _, x_true = gcd_predictor_corrector(T_roll, N_roll, x0, pars, p, kernel_name)
        t_pred, x_pred = rollout_surrogate(best_bundle, T_roll, N_roll, x0, pars, p, kernel_name)

        metrics = regression_metrics(x_true, x_pred)
        rollout_summary.append({"kernel": kernel_name, "p": p, **metrics})

        plot_rollout_comparison(
            t_true, x_true, x_pred, kernel_name, p,
            save_path=f"figures/rollout_{kernel_name}.png"
        )

    rollout_rank = sorted(rollout_summary, key=lambda d: d["RMSE"])

    # ---- Save machine-readable outputs ----
    with open(os.path.join(output_dir, "validation_results.json"), "w") as f:
        json.dump(val_results, f, indent=2)

    with open(os.path.join(output_dir, "kernel_summary.json"), "w") as f:
        json.dump(kernel_summary, f, indent=2)

    with open(os.path.join(output_dir, "optimizer_benchmark.json"), "w") as f:
        json.dump(benchmark_table, f, indent=2)

    with open(os.path.join(output_dir, "rollout_summary.json"), "w") as f:
        json.dump(rollout_summary, f, indent=2)

    def write_table_txt(path, rows):
        if not rows:
            return
        keys = list(rows[0].keys())
        with open(path, "w") as f:
            f.write(",".join(keys) + "\n")
            for r in rows:
                f.write(",".join(str(r[k]) for k in keys) + "\n")

    write_table_txt(os.path.join(output_dir, "validation_results.csv"), val_results)
    write_table_txt(os.path.join(output_dir, "kernel_summary.csv"), kernel_summary)
    write_table_txt(os.path.join(output_dir, "optimizer_benchmark.csv"), benchmark_table)
    write_table_txt(os.path.join(output_dir, "rollout_summary.csv"), rollout_summary)

    summary = {
        "device": DEVICE,
        "validation_results": val_results,
        "best_optimizer": best_opt,
        "optimizer_benchmark": benchmark_table,
        "rollout_summary": rollout_summary,
        "best_kernel_by_rollout_rmse": rollout_rank[0]["kernel"] if rollout_rank else None,
        "best_kernel_metrics": rollout_rank[0] if rollout_rank else None,
        "num_dataset_samples": int(X.shape[0]),
        "input_dim": int(X.shape[1]),
        "output_dim": int(Y.shape[1]),
        "figures_saved_in": "figures",
        "tables_saved_in": output_dir,
    }

    with open(os.path.join(output_dir, "summary.json"), "w") as f:
        json.dump(summary, f, indent=2)

    return summary


if __name__ == "__main__":
    # quick=True for smoke test; quick=False for fuller experiment suite
    summary = run_all_experiments(output_dir="outputs", quick=False)
    print("\n=== SUMMARY ===")
    print(json.dumps(summary, indent=2))
