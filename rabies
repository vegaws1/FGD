    "sigma_d": 1.0 / 7.0,
}

BASE_X0 = np.array([1800.0, 25.0, 3.0, 60.0, 900.0, 35.0, 6.0, 220.0], dtype=float)

# ============================================================
# 3) Tempered rabies model and numerical solver
# ============================================================
def rabies_rhs(X: np.ndarray, pars: Dict[str, float]) -> np.ndarray:
    Uh, Eh, Ih, Rh, Sd, Ed, Id, Vd = X
    dUh = pars["Lambda_h"] + pars["omega_h"] * Rh - pars["beta_h1"] * Uh * Ih - pars["beta_h2"] * Uh * Id - pars["mu_h"] * Uh
    dEh = pars["beta_h1"] * Uh * Ih + pars["beta_h2"] * Uh * Id - (pars["phi_h"] + pars["rho_h"] + pars["mu_h"]) * Eh
    dIh = pars["rho_h"] * Eh - (pars["mu_h"] + pars["sigma_h"]) * Ih
    dRh = pars["phi_h"] * Eh - (pars["omega_h"] + pars["mu_h"]) * Rh
    dSd = pars["Lambda_d"] - pars["beta_d"] * Sd * Id + pars["omega_d"] * Vd - (pars["phi_d"] + pars["mu_d"]) * Sd
    dEd = pars["beta_d"] * Sd * Id - (pars["rho_d"] + pars["mu_d"]) * Ed
    dId = pars["rho_d"] * Ed - (pars["mu_d"] + pars["sigma_d"]) * Id
    dVd = pars["phi_d"] * Sd - (pars["omega_d"] + pars["mu_d"]) * Vd
    return np.array([dUh, dEh, dIh, dRh, dSd, dEd, dId, dVd], dtype=float)


def tempered_interval_weight(xi: float, lam: float, left: float, right: float) -> float:
    if right <= left:
        return 0.0
    if lam == 0.0:
        return (right ** xi - left ** xi) / xi
    return (gamma_fn(xi) / (lam ** xi)) * (gammainc(xi, lam * right) - gammainc(xi, lam * left))


def all_tempered_weights(n_plus_1: int, h: float, xi: float, lam: float) -> np.ndarray:
    n = n_plus_1 - 1
    out = np.zeros(n_plus_1, dtype=float)
    for j in range(n_plus_1):
        left = (n - j) * h
        right = (n + 1 - j) * h
        out[j] = tempered_interval_weight(xi, lam, left, right)
    return out


def tempered_pc_solver(T: float, N: int, x0: np.ndarray, pars: Dict[str, float], xi: float, lam: float, a: float = 0.0):
    t = np.linspace(a, T, N + 1)
    h = (T - a) / N
    gamma_xi = gamma_fn(xi)
    X = np.zeros((N + 1, NUM_STATES), dtype=float)
    X[0] = np.maximum(x0, 0.0)
    F = np.zeros_like(X)
    F[0] = rabies_rhs(X[0], pars)

    for n in range(N):
        B = all_tempered_weights(n + 1, h, xi, lam)
        pred = math.exp(-lam * (t[n + 1] - a)) * x0 + (B[:, None] * F[:n + 1]).sum(axis=0) / gamma_xi
        pred = np.maximum(pred, 0.0)
        if n == 0:
            corr = math.exp(-lam * (t[n + 1] - a)) * x0 + (B[n] * rabies_rhs(pred, pars)) / gamma_xi
        else:
            corr = math.exp(-lam * (t[n + 1] - a)) * x0 + ((B[:n, None] * F[:n]).sum(axis=0) + B[n] * rabies_rhs(pred, pars)) / gamma_xi
        X[n + 1] = np.maximum(corr, 0.0)
        F[n + 1] = rabies_rhs(X[n + 1], pars)
    return t, X

# ============================================================
# 4) Validation and parametric summaries
# ============================================================
def relative_l2_error(x_num: np.ndarray, x_ref: np.ndarray) -> float:
    return float(np.linalg.norm(x_num - x_ref) / (np.linalg.norm(x_ref) + 1e-12))


def validation_study(T=40.0, xi=0.85, lam=0.15, x0=BASE_X0, pars=BASE_PARAMS):
    step_list = [100, 200, 400, 800]
    ref_factor = 8
    rows = []
    for N in step_list:
        _, xn = tempered_pc_solver(T, N, x0, pars, xi, lam)
        _, xr = tempered_pc_solver(T, ref_factor * N, x0, pars, xi, lam)
        xr = xr[::ref_factor]
        rows.append({"N": N, "h": T / N, "rel_L2_error": relative_l2_error(xn, xr)})
    for k in range(1, len(rows)):
        rows[k]["estimated_order"] = math.log((rows[k-1]["rel_L2_error"] + 1e-16) / (rows[k]["rel_L2_error"] + 1e-16)) / math.log(rows[k-1]["h"] / rows[k]["h"])
    return rows


def summarize_traj(t: np.ndarray, X: np.ndarray, xi: float, lam: float):
    burden = X[:, 1] + X[:, 2] + X[:, 5] + X[:, 6]
    k = int(np.argmax(burden))
    return {
        "xi": float(xi), "lambda": float(lam),
        "peak_burden": float(burden[k]), "peak_time": float(t[k]),
        "final_burden": float(burden[-1]),
        "final_human_infected": float(X[-1, 2]),
        "final_dog_infected": float(X[-1, 6]),
        "final_vaccinated_dogs": float(X[-1, 7]),
    }


def simulate_xi_grid(T=60.0, N=800, xi_values=(0.65,0.80,0.95), lam=0.15):
    rows, trajs = [], {}
    for xi in xi_values:
        t, X = tempered_pc_solver(T, N, BASE_X0, BASE_PARAMS, xi, lam)
        rows.append(summarize_traj(t, X, xi, lam))
        trajs[xi] = (t, X)
    return rows, trajs


def simulate_lambda_grid(T=60.0, N=800, lam_values=(0.0,0.10,0.25), xi=0.85):
    rows, trajs = [], {}
    for lam in lam_values:
        t, X = tempered_pc_solver(T, N, BASE_X0, BASE_PARAMS, xi, lam)
        rows.append(summarize_traj(t, X, xi, lam))
        trajs[lam] = (t, X)
    return rows, trajs

# ============================================================
# 5) Data generation
# ============================================================
def sample_random_params(base: Dict[str,float], scale: float = 0.15) -> Dict[str,float]:
    p = dict(base)
    for k in ["beta_h1","beta_h2","beta_d","phi_h","rho_h","phi_d","rho_d","omega_d"]:
        p[k] = base[k] * (1.0 + np.random.uniform(-scale, scale))
    for k in ["mu_h","mu_d","sigma_h","sigma_d","omega_h","Lambda_h","Lambda_d"]:
        p[k] = base[k] * (1.0 + np.random.uniform(-0.10, 0.10))
    return p


def sample_random_x0(base_x0: np.ndarray, scale: float = 0.20) -> np.ndarray:
    return np.maximum(base_x0 * (1.0 + np.random.uniform(-scale, scale, size=base_x0.shape)), 1e-6)


def z_state(X: np.ndarray) -> np.ndarray:
    return np.log1p(np.maximum(X, 0.0))


def inv_z_state(Z: np.ndarray) -> np.ndarray:
    return np.maximum(np.expm1(Z), 0.0)


def build_feature_from_history(Zhist: np.ndarray, n: int, history_steps: int, t_curr: float, h: float, xi: float, lam: float, pars: Dict[str,float]) -> np.ndarray:
    blocks = []
    for k in range(history_steps):
        idx = max(0, n - history_steps + 1 + k)
        blocks.append(Zhist[idx])
    pars_feat = np.array([pars[k] for k in PARAM_KEYS], dtype=float)
    return np.concatenate(blocks + [np.array([t_curr, h, xi, lam], dtype=float), pars_feat])


def generate_trajectories(num_trajectories: int, T: float, N: int, xi_choices, lam_choices) -> List[dict]:
    out = []
    for _ in range(num_trajectories):
        xi = float(random.choice(xi_choices))
        lam = float(random.choice(lam_choices))
        pars = sample_random_params(BASE_PARAMS, scale=0.12)
        x0 = sample_random_x0(BASE_X0, scale=0.20)
        t, X = tempered_pc_solver(T, N, x0, pars, xi, lam)
        Z = z_state(X)
        out.append({"t": t, "X": X, "Z": Z, "xi": xi, "lam": lam, "pars": pars, "x0": x0})
    return out

# ============================================================
# 6) Feature/target scalers
# ============================================================
class StandardScalerNP:
    def fit(self, X: np.ndarray):
        self.mean_ = X.mean(axis=0)
        self.std_ = X.std(axis=0) + 1e-8
        return self
    def transform(self, X: np.ndarray) -> np.ndarray:
        return (X - self.mean_) / self.std_
    def inverse_transform(self, X: np.ndarray) -> np.ndarray:
        return X * self.std_ + self.mean_

    def to_torch(self, device=DEVICE):
        """Convert scaler parameters to torch tensors for differentiable inverse scaling"""
        self.mean_t = torch.tensor(self.mean_, dtype=torch.float32, device=device)
        self.std_t = torch.tensor(self.std_, dtype=torch.float32, device=device)
        return self

    def inverse_transform_torch(self, X_s: torch.Tensor) -> torch.Tensor:
        """Differentiable inverse scaling for torch tensors"""
        return X_s * self.std_t + self.mean_t

# ============================================================
# 7) Dataset builders
# ============================================================
def make_one_step_arrays(trajectories: List[dict], history_steps: int) -> Tuple[np.ndarray,np.ndarray]:
    Xs, Ys = [], []
    for tr in trajectories:
        t, Z, xi, lam, pars = tr["t"], tr["Z"], tr["xi"], tr["lam"], tr["pars"]
        h = t[1] - t[0]
        for n in range(len(t) - 1):
            feat = build_feature_from_history(Z, n, history_steps, t[n], h, xi, lam, pars)
            dz = Z[n + 1] - Z[n]
            Xs.append(feat)
            Ys.append(dz)
    return np.asarray(Xs, dtype=np.float32), np.asarray(Ys, dtype=np.float32)


def split_trajectories(trajectories: List[dict], train_ratio=0.70, val_ratio=0.15):
    idx = np.arange(len(trajectories))
    np.random.shuffle(idx)
    trajectories = [trajectories[i] for i in idx]
    n = len(trajectories)
    n_train = int(train_ratio * n)
    n_val = int(val_ratio * n)
    train = trajectories[:n_train]
    val = trajectories[n_train:n_train+n_val]
    test = trajectories[n_train+n_val:]
    return train, val, test

