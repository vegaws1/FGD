def run_all(output_dir="outputs_tempered_rabies_auto", quick=False):
    os.makedirs(output_dir, exist_ok=True)

    # Numerical validation + dynamics (always saved)
    val_results = validation_study(T=20.0 if quick else 40.0, xi=0.85, lam=0.15)
    xi_summary, xi_trajs = simulate_xi_grid(T=30.0 if quick else 60.0, N=400 if quick else 800, xi_values=(0.65,0.80,0.95), lam=0.15)
    lam_summary, lam_trajs = simulate_lambda_grid(T=30.0 if quick else 60.0, N=400 if quick else 800, lam_values=(0.0,0.10,0.25), xi=0.85)
    plot_states_grid(xi_trajs, varying="xi", fixed_value=0.15, fname_prefix="rabies_xi_compare")
    plot_states_grid(lam_trajs, varying="lambda", fixed_value=0.85, fname_prefix="rabies_lambda_compare")

    best = train_until_excellent(output_dir=output_dir, quick=quick)
    if best is None:
        print("No best model found.")
        return {}
    plot_rollout_example(best)

    summary = {
        "device": DEVICE,
        "validation_results": val_results,
        "xi_dynamics_summary": xi_summary,
        "lambda_dynamics_summary": lam_summary,
        "best_config": best["config"],
        "one_step_metrics": best["one_step_metrics"],
        "rollout_metrics": best["rollout_metrics"],
        "mean_rollout_r2": best["mean_rollout_r2"],
        "mean_rollout_rmse": best["mean_rollout_rmse"],
        "history_steps": best["history_steps"],
        "excellent_reached": bool(best["one_step_metrics"]["R2"] >= TARGET_ONE_STEP_R2 and best["mean_rollout_r2"] >= TARGET_ROLLOUT_R2 and best["mean_rollout_rmse"] <= TARGET_ROLLOUT_RMSE),
        "targets": {
            "one_step_R2": TARGET_ONE_STEP_R2,
            "mean_rollout_R2": TARGET_ROLLOUT_R2,
            "mean_rollout_RMSE": TARGET_ROLLOUT_RMSE,
        },
        "figures_saved_in": "figures",
        "tables_saved_in": output_dir,
    }

    with open(os.path.join(output_dir, "summary.json"), "w", encoding="utf-8") as f:
        json.dump(summary, f, indent=2)
    with open(os.path.join(output_dir, "one_step_metrics.json"), "w", encoding="utf-8") as f:
        json.dump(best["one_step_metrics"], f, indent=2)
    with open(os.path.join(output_dir, "rollout_metrics.json"), "w", encoding="utf-8") as f:
        json.dump(best["rollout_metrics"], f, indent=2)
    with open(os.path.join(output_dir, "validation_results.json"), "w", encoding="utf-8") as f:
        json.dump(val_results, f, indent=2)
    with open(os.path.join(output_dir, "xi_dynamics_summary.json"), "w", encoding="utf-8") as f:
        json.dump(xi_summary, f, indent=2)
    with open(os.path.join(output_dir, "lambda_dynamics_summary.json"), "w", encoding="utf-8") as f:
        json.dump(lam_summary, f, indent=2)

    write_table_csv(os.path.join(output_dir, "validation_results.csv"), val_results)
    write_table_csv(os.path.join(output_dir, "xi_dynamics_summary.csv"), xi_summary)
    write_table_csv(os.path.join(output_dir, "lambda_dynamics_summary.csv"), lam_summary)
    write_table_csv(os.path.join(output_dir, "rollout_metrics.csv"), best["rollout_metrics"])

    return summary


if __name__ == "__main__":
    QUICK = False
    summary = run_all(output_dir="outputs_tempered_rabies_auto", quick=QUICK)
    print("\n=== SUMMARY ===")
    print(json.dumps(summary, indent=2))
