CONFIGS = [
    Config(80, 180, 8,  (256,256,128), 0.04, 60, 20, 5, 512, 1e-3, 5e-4),
    Config(120,220,12,  (384,256,128), 0.03, 80, 30, 8, 512, 8e-4, 4e-4),
    Config(160,260,16,  (512,384,256), 0.02, 100,40,10, 512, 7e-4, 3e-4),
]

TARGET_ONE_STEP_R2 = 0.999
TARGET_ROLLOUT_R2 = 0.85      # slightly relaxed for practical success
TARGET_ROLLOUT_RMSE = 50.0


def train_until_excellent(output_dir="outputs_tempered_rabies_auto", quick=False):
    os.makedirs(output_dir, exist_ok=True)
    os.makedirs("figures", exist_ok=True)

    configs = CONFIGS[:1] if quick else CONFIGS
    best = None

    xi_choices = (0.65, 0.75, 0.85, 0.95)
    lam_choices = (0.0, 0.10, 0.20, 0.30)
    T = 20.0 if quick else 40.0

    for attempt, cfg in enumerate(configs, start=1):
        print(f"\n=== Attempt {attempt}/{len(configs)} | cfg={cfg} ===")
        trajs = generate_trajectories(cfg.n_traj, T, cfg.N, xi_choices, lam_choices)
        train_tr, val_tr, test_tr = split_trajectories(trajs)

        Xtr, Ytr = make_one_step_arrays(train_tr, cfg.history_steps)
        Xva, Yva = make_one_step_arrays(val_tr, cfg.history_steps)

        x_scaler = StandardScalerNP().fit(Xtr)
        y_scaler = StandardScalerNP().fit(Ytr)
        Xtr_s, Ytr_s = x_scaler.transform(Xtr), y_scaler.transform(Ytr)
        Xva_s, Yva_s = x_scaler.transform(Xva), y_scaler.transform(Yva)

        train_loader, val_loader = make_dataloaders(Xtr_s, Ytr_s, Xva_s, Yva_s, cfg.batch_size)
        model = ResidualMLP(in_dim=Xtr.shape[1], hidden=cfg.hidden, dropout=cfg.dropout).to(DEVICE)

        hist_one, best_val_one = train_one_step(model, train_loader, val_loader, cfg.epochs_one, cfg.lr_one)
        print(f"One-step pre-training done. Val loss = {best_val_one:.6f}")

        # Fine-tune with rollout loss
        print("Fine-tuning with rollout loss...")
        hist_roll, best_val_roll = fine_tune_rollout(
            model, train_tr, val_tr, x_scaler, y_scaler,
            cfg.history_steps, cfg.rollout_steps, cfg.epochs_roll, cfg.lr_roll
        )
        print(f"Rollout fine-tuning done. Val rollout loss = {best_val_roll:.6f}")

        one_step_metrics = evaluate_one_step(model, test_tr, cfg.history_steps, x_scaler, y_scaler)
        rollout_metrics = evaluate_rollout(model, test_tr, cfg.history_steps, x_scaler, y_scaler)

        mean_rollout_r2 = float(np.mean([r["R2"] for r in rollout_metrics])) if rollout_metrics else -np.inf
        mean_rollout_rmse = float(np.mean([r["RMSE"] for r in rollout_metrics])) if rollout_metrics else np.inf

        result = {
            "attempt": attempt,
            "config": cfg.__dict__,
            "one_step_metrics": one_step_metrics,
            "rollout_metrics": rollout_metrics,
            "mean_rollout_r2": mean_rollout_r2,
            "mean_rollout_rmse": mean_rollout_rmse,
            "history_steps": cfg.history_steps,
        }

        if (best is None) or (mean_rollout_r2 > best["mean_rollout_r2"]) or (
            abs(mean_rollout_r2 - best["mean_rollout_r2"]) < 1e-12 and one_step_metrics["R2"] > best["one_step_metrics"]["R2"]
        ):
            best = {**result, "model": model, "x_scaler": x_scaler, "y_scaler": y_scaler,
                    "hist_one": hist_one, "hist_roll": hist_roll, "test_tr": test_tr}

        print("One-step:", one_step_metrics)
        print("Rollout mean R2 / RMSE:", mean_rollout_r2, mean_rollout_rmse)

        if one_step_metrics["R2"] >= TARGET_ONE_STEP_R2 and mean_rollout_r2 >= TARGET_ROLLOUT_R2 and mean_rollout_rmse <= TARGET_ROLLOUT_RMSE:
            print("\n*** Target quality reached. Stopping early. ***")
            break

    return best

