class ResidualMLP(nn.Module):
    def __init__(self, in_dim: int, out_dim: int = NUM_STATES, hidden=(256,256,128), dropout=0.05):
        super().__init__()
        layers = []
        prev = in_dim
        for h in hidden:
            layers += [nn.Linear(prev, h), nn.ReLU(), nn.Dropout(dropout)]
            prev = h
        layers += [nn.Linear(prev, out_dim)]
        self.net = nn.Sequential(*layers)
    def forward(self, x):
        return self.net(x)

# ============================================================
# 9) Training helpers (differentiable rollout loss)
# ============================================================
def regression_metrics(y_true: np.ndarray, y_pred: np.ndarray) -> Dict[str,float]:
    mse = np.mean((y_true - y_pred) ** 2)
    rmse = float(np.sqrt(mse))
    mae = float(np.mean(np.abs(y_true - y_pred)))
    ss_res = float(np.sum((y_true - y_pred) ** 2))
    ss_tot = float(np.sum((y_true - y_true.mean(axis=0, keepdims=True)) ** 2) + 1e-12)
    r2 = 1.0 - ss_res / ss_tot
    return {"RMSE": rmse, "MAE": mae, "R2": r2}


def train_one_step(model, train_loader, val_loader, epochs, lr):
    opt = torch.optim.Adam(model.parameters(), lr=lr)
    sch = torch.optim.lr_scheduler.ReduceLROnPlateau(opt, mode="min", factor=0.5, patience=4)
    loss_fn = nn.MSELoss()
    best_state, best_val, bad = None, float("inf"), 0
    hist = {"train_loss": [], "val_loss": []}

    for _ in range(epochs):
        model.train()
        tr_loss, ntr = 0.0, 0
        for xb, yb in train_loader:
            xb, yb = xb.to(DEVICE), yb.to(DEVICE)
            opt.zero_grad()
            pred = model(xb)
            loss = loss_fn(pred, yb)
            loss.backward()
            nn.utils.clip_grad_norm_(model.parameters(), 5.0)
            opt.step()
            tr_loss += loss.item() * len(xb)
            ntr += len(xb)
        tr_loss /= max(1, ntr)

        model.eval()
        va_loss, nva = 0.0, 0
        with torch.no_grad():
            for xb, yb in val_loader:
                xb, yb = xb.to(DEVICE), yb.to(DEVICE)
                pred = model(xb)
                loss = loss_fn(pred, yb)
                va_loss += loss.item() * len(xb)
                nva += len(xb)
        va_loss /= max(1, nva)
        sch.step(va_loss)
        hist["train_loss"].append(tr_loss)
        hist["val_loss"].append(va_loss)
        if va_loss < best_val:
            best_val = va_loss
            best_state = {k: v.detach().cpu().clone() for k, v in model.state_dict().items()}
            bad = 0
        else:
            bad += 1
            if bad >= 10:
                break
    if best_state is not None:
        model.load_state_dict(best_state)
    return hist, best_val


def rollout_loss_batch(model, batch_trajs: List[dict], x_scaler, y_scaler, history_steps: int, rollout_steps: int) -> torch.Tensor:
    """Fully differentiable rollout loss (no .detach().cpu().numpy())"""
    losses = []
    mse = nn.MSELoss()

    # Convert scalers to torch for differentiable inverse transform
    x_scaler.to_torch(DEVICE)
    y_scaler.to_torch(DEVICE)

    for tr in batch_trajs:
        t = tr["t"]
        Z = torch.tensor(tr["Z"], dtype=torch.float32, device=DEVICE)
        xi = tr["xi"]
        lam = tr["lam"]
        pars = tr["pars"]
        h = t[1] - t[0]

        max_start = len(t) - rollout_steps - 1
        if max_start <= history_steps:
            continue
        n0 = random.randint(history_steps - 1, max_start)

        # initial history (as tensors)
        hist = [Z[max(0, n0 - history_steps + 1 + k)].clone() for k in range(history_steps)]

        step_losses = []
        for j in range(rollout_steps):
            # build feature (as numpy for scaling, but we need torch tensors for differentiable path)
            # We'll reconstruct the feature in torch using the same logic but from tensors
            # Simpler: use a helper that builds from torch tensors
            feat = build_feature_from_history_torch(hist, history_steps, t[n0 + j], h, xi, lam, pars, DEVICE)
            # Normalize using x_scaler (which has torch mean/std)
            feat_s = (feat - x_scaler.mean_t) / x_scaler.std_t
            dz_pred_s = model(feat_s.unsqueeze(0)).squeeze(0)
            # Inverse scale the delta prediction (differentiable)
            dz_pred = y_scaler.inverse_transform_torch(dz_pred_s)

            z_curr = hist[-1]
            z_next_pred = z_curr + dz_pred
            z_true = Z[n0 + j + 1]

            step_losses.append(mse(z_next_pred, z_true))

            # Update history: remove first, append predicted (detach? no, keep graph but we can detach to avoid explosion)
            # For stability, we detach the predicted state (stop gradient from previous steps)
            hist = hist[1:] + [z_next_pred.detach()]   # detach to avoid deep graph but keep gradient for current step? Better to keep for short rollout
            # Actually, we want gradients through time, but to avoid memory blow we keep only last step's grad.
            # For simplicity, we keep the graph but limit rollout steps to small number (5-10). It's fine.
            # Removing detach would keep full graph; let's keep it to allow learning through time.
            # But to avoid OOM, we keep detach. The loss already includes each step individually.
        if step_losses:
            losses.append(torch.stack(step_losses).mean())
    if not losses:
        return torch.tensor(0.0, device=DEVICE, requires_grad=True)
    return torch.stack(losses).mean()


def build_feature_from_history_torch(hist: List[torch.Tensor], history_steps: int, t_curr: float, h: float, xi: float, lam: float, pars: Dict, device):
    """Build feature tensor directly from list of torch tensors"""
    # hist: list of tensors shape (state_dim,)
    blocks = []
    # hist already contains exactly history_steps tensors in correct order
    for z in hist:
        blocks.append(z)
    # Additional features
    t_t = torch.tensor([t_curr, h, xi, lam], dtype=torch.float32, device=device)
    pars_feat = torch.tensor([pars[k] for k in PARAM_KEYS], dtype=torch.float32, device=device)
    return torch.cat(blocks + [t_t, pars_feat])


def fine_tune_rollout(model, train_trajs, val_trajs, x_scaler, y_scaler, history_steps, rollout_steps, epochs, lr, batch_traj=12):
    opt = torch.optim.Adam(model.parameters(), lr=lr)
    best_state, best_val, bad = None, float("inf"), 0
    hist = {"train_loss": [], "val_loss": []}

    for ep in range(epochs):
        model.train()
        random.shuffle(train_trajs)
        batch_losses = []
        for i in range(0, len(train_trajs), batch_traj):
            chunk = train_trajs[i:i+batch_traj]
            opt.zero_grad()
            loss = rollout_loss_batch(model, chunk, x_scaler, y_scaler, history_steps, rollout_steps)
            loss.backward()
            nn.utils.clip_grad_norm_(model.parameters(), 5.0)
            opt.step()
            batch_losses.append(float(loss.item()))
        tr_loss = float(np.mean(batch_losses)) if batch_losses else 0.0

        model.eval()
        val_losses = []
        with torch.no_grad():
            for i in range(0, len(val_trajs), batch_traj):
                chunk = val_trajs[i:i+batch_traj]
                loss = rollout_loss_batch(model, chunk, x_scaler, y_scaler, history_steps, rollout_steps)
                val_losses.append(float(loss.item()))
        va_loss = float(np.mean(val_losses)) if val_losses else 0.0

        hist["train_loss"].append(tr_loss)
        hist["val_loss"].append(va_loss)

        if va_loss < best_val:
            best_val = va_loss
            best_state = {k: v.detach().cpu().clone() for k, v in model.state_dict().items()}
            bad = 0
        else:
            bad += 1
            if bad >= 8:
                break
    if best_state is not None:
        model.load_state_dict(best_state)
    return hist, best_val

