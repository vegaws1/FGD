# 10) Evaluation
# ============================================================
def make_dataloaders(trainX, trainY, valX, valY, batch_size):
    class DS(Dataset):
        def __init__(self, X, Y):
            self.X = torch.tensor(X, dtype=torch.float32)
            self.Y = torch.tensor(Y, dtype=torch.float32)
        def __len__(self): return len(self.X)
        def __getitem__(self, i): return self.X[i], self.Y[i]
    return (
        DataLoader(DS(trainX, trainY), batch_size=batch_size, shuffle=True),
        DataLoader(DS(valX, valY), batch_size=batch_size, shuffle=False),
    )


def evaluate_one_step(model, test_trajs, history_steps, x_scaler, y_scaler):
    y_true, y_pred = [], []
    model.eval()
    with torch.no_grad():
        for tr in test_trajs:
            t, X, Z, xi, lam, pars = tr["t"], tr["X"], tr["Z"], tr["xi"], tr["lam"], tr["pars"]
            h = t[1] - t[0]
            for n in range(len(t) - 1):
                feat = build_feature_from_history(Z, n, history_steps, t[n], h, xi, lam, pars)
                feat_s = x_scaler.transform(feat[None, :])
                dz_pred_s = model(torch.tensor(feat_s, dtype=torch.float32, device=DEVICE)).cpu().numpy()
                dz_pred = y_scaler.inverse_transform(dz_pred_s)[0]
                z_next_pred = Z[n] + dz_pred
                x_next_pred = inv_z_state(z_next_pred)
                y_pred.append(x_next_pred)
                y_true.append(X[n + 1])
    return regression_metrics(np.asarray(y_true), np.asarray(y_pred))


def rollout_model(model, tr: dict, history_steps: int, x_scaler, y_scaler):
    t, X, Z, xi, lam, pars = tr["t"], tr["X"], tr["Z"], tr["xi"], tr["lam"], tr["pars"]
    h = t[1] - t[0]
    model.eval()
    Zhat = np.zeros_like(Z)
    Zhat[:history_steps] = Z[:history_steps]
    hist = [Zhat[k].copy() for k in range(history_steps)]
    with torch.no_grad():
        for n in range(history_steps - 1, len(t) - 1):
            feat = build_feature_from_history(np.array(hist), history_steps - 1, history_steps, t[n], h, xi, lam, pars)
            feat_s = x_scaler.transform(feat[None, :])
            dz_pred_s = model(torch.tensor(feat_s, dtype=torch.float32, device=DEVICE)).cpu().numpy()
            dz_pred = y_scaler.inverse_transform(dz_pred_s)[0]
            z_next = hist[-1] + dz_pred
            Zhat[n + 1] = z_next
            hist = hist[1:] + [z_next.copy()]
    Xhat = inv_z_state(Zhat)
    return t, X, Xhat


def evaluate_rollout(model, test_trajs, history_steps, x_scaler, y_scaler):
    rows = []
    for tr in test_trajs[:3]:
        t, X, Xhat = rollout_model(model, tr, history_steps, x_scaler, y_scaler)
        m = regression_metrics(X, Xhat)
        rows.append({"xi": float(tr["xi"]), "lambda": float(tr["lam"]), **m})
    return rows

