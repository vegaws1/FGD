def plot_states_grid(trajectories, varying="xi", fixed_value=0.15, fname_prefix="rabies_compare"):
    os.makedirs("figures", exist_ok=True)
    for i, name in enumerate(STATE_NAMES):
        plt.figure(figsize=(8,5))
        for key, (t, X) in trajectories.items():
            label = f"{varying}={key}"
            plt.plot(t, X[:, i], label=label)
        plt.xlabel("Time")
        plt.ylabel(name)
        plt.title(f"{name} for different {varying} ({'lambda' if varying=='xi' else 'xi'}={fixed_value})")
        plt.grid(True, alpha=0.3)
        plt.legend()
        plt.tight_layout()
        plt.savefig(f"figures/{fname_prefix}_{name}.png", dpi=180)
        plt.close()


def plot_rollout_example(best_bundle, save_dir="figures"):
    os.makedirs(save_dir, exist_ok=True)
    for tr in best_bundle["test_tr"][:2]:
        t, X, Xhat = rollout_model(best_bundle["model"], tr, best_bundle["history_steps"], best_bundle["x_scaler"], best_bundle["y_scaler"])
        fig, axes = plt.subplots(4, 2, figsize=(13, 12), sharex=True)
        axes = axes.flatten()
        for i, name in enumerate(STATE_NAMES):
            axes[i].plot(t, X[:, i], label="Numerical solver", lw=2)
            axes[i].plot(t, Xhat[:, i], '--', label="DNN surrogate", lw=1.8)
            axes[i].set_title(f"{name} | xi={tr['xi']}, lambda={tr['lam']}")
            axes[i].grid(True, alpha=0.3)
            axes[i].legend(fontsize=8)
        plt.tight_layout()
        plt.savefig(os.path.join(save_dir, f"rollout_xi_{str(tr['xi']).replace('.','_')}_lam_{str(tr['lam']).replace('.','_')}.png"), dpi=180)
        plt.close(fig)


def write_table_csv(path, rows):
    if not rows:
        return
    keys = list(rows[0].keys())
    with open(path, "w", encoding="utf-8") as f:
        f.write(",".join(keys) + "\n")
        for r in rows:
            f.write(",".join(str(r[k]) for k in keys) + "\n")

